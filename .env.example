# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Admin panel password (used for create/edit/delete events and settle toggle)
ADMIN_PASSWORD="your-admin-password"

# (選填) 管理員 session 簽章金鑰。未設定時退回使用 ADMIN_PASSWORD 簽章，
# 此時「更改密碼」會讓所有既有登入失效。設定獨立金鑰可讓兩者解耦。
# 產生方式範例：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET="a-long-random-string"
